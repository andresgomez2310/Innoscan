// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NEXT_PUBLIC_SUPABASE_URL")
}

// ── Datos compartidos — Flyweight 

model Category {
  id    String @id @default(cuid())
  label String
  icon  String
  color String
  scans Scan[]
}

model TransformationType {
  id          String               @id @default(cuid())
  name        String
  strategyKey String               // reuseStrategy | transformStrategy | reconfigureStrategy
  description String
  results     RecommendationResult[]
}

// ── Entidades principales ─────────────────────────────────────

model Scan {
  id          String   @id @default(cuid())
  itemName    String
  imageUrl    String?
  categoryId  String
  condition   String
  description String?
  tags        String[]
  status      ScanStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category               @relation(fields: [categoryId], references: [id])
  results  RecommendationResult[]
}

model RecommendationResult {
  id                 String   @id @default(cuid())
  scanId             String
  transformationTypeId String
  recommendations    Json     // RecommendationItem[]
  confidence         Int
  processingTimeMs   Int
  status             String   @default("COMPLETE")
  createdAt          DateTime @default(now())

  scan               Scan               @relation(fields: [scanId], references: [id], onDelete: Cascade)
  transformationType TransformationType @relation(fields: [transformationTypeId], references: [id])
  feedback           Feedback[]
}

model Feedback {
  id        String   @id @default(cuid())
  resultId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  result RecommendationResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
}

enum ScanStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}
